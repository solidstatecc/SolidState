# --- Webhook ---
# Long random string. Same value goes in Vercel env.
WEBHOOK_SECRET=replace-me-with-32-bytes-base64

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SKILLS_BUCKET=skills

# --- Sandbox ---
# nemoclaw | docker
SANDBOX_RUNTIME=nemoclaw
NEMOCLAW_IMAGE=nvidia/nemoclaw:latest
RUN_TIMEOUT_SECS=120
MAX_OUTPUT_BYTES=1048576

# --- Telegram admin ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Brain (Anthropic-powered conversational layer) ---
ANTHROPIC_API_KEY=
BRAIN_MODEL=claude-sonnet-4-6
WORKSPACE_PATH=/sandbox/.openclaw-data/workspace
BRAIN_MAX_TURNS=8
BRAIN_HISTORY_LIMIT=20

# --- Dev only ---
ALLOW_INTERNAL_RUN=0
STAGE_DIR=/tmp/solidstate-skills
